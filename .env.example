# Google Gemini is the default LLM backend for generation.
# The released 200K dataset was generated with the historical
# gemini-3.1-flash-lite-preview model name. That preview endpoint has been
# replaced for new runs by gemini-3.1-flash-lite.
LLM_PROVIDER=gemini
GOOGLE_API_KEY=replace-with-your-key

# Optional OpenAI-compatible HTTP backend. The repository does not execute
# model weights itself; start vLLM/Ollama/TGI/LiteLLM/OpenAI separately and
# point this configuration at its /v1 endpoint.
# LLM_PROVIDER=local
# LOCAL_LLM_URL=http://127.0.0.1:8000/v1
# LOCAL_LLM_MODEL=replace-with-served-model-name
# LOCAL_LLM_API_KEY=not-needed

# Optional model role overrides.
# MIRAGE_MODEL_ARTIFACT_BULK=gemini-3.1-flash-lite
# MIRAGE_MODEL_ARTIFACT_PRO=gemini-3.1-flash-lite
# MIRAGE_DEFAULT_GEMINI_MODEL=gemini-3.1-flash-lite
# MIRAGE_DEFAULT_GEMINI_PRO_MODEL=gemini-3.1-flash-lite
